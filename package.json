{
  "name": "paydayplanners-mobile-app",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:ios:preview": "eas build --platform ios --profile preview",
    "build:android:preview": "eas build --platform android --profile preview",
    "build:android:apk": "eas build --platform android --profile production-apk",
    "build:ios:production": "eas build --platform ios --profile production",
    "build:android:production": "eas build --platform android --profile production",
    "build:ipa": "npm run build:ios:production",
    "build:aab": "npm run build:android:production",
    "build:apk": "npm run build:android:apk",
    "ship:ios": "node scripts/ship.cjs ios",
    "ship:android": "node scripts/ship.cjs android",
    "ship": "node scripts/ship.cjs all",
    "dev": "node scripts/switch-endpoints.cjs local",
    "prod": "node scripts/switch-endpoints.cjs prod",
    "env": "node scripts/switch-endpoints.cjs status",
    "env:local": "node scripts/switch-endpoints.cjs local",
    "env:prod": "node scripts/switch-endpoints.cjs prod",
    "env:status": "node scripts/switch-endpoints.cjs status",
    "ota": "eas update --channel production --environment production",
    "ota:ios": "eas update --platform ios --channel production --environment production",
    "ota:android": "eas update --platform android --channel production --environment production",
    "ota:all": "npm run ota",
    "ota:preview": "eas update --channel preview --environment preview",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "expo:config:check": "npx expo config --json > /dev/null"
  },
  "dependencies": {
    "@expo/metro-runtime": "~55.0.6",
    "@expo/vector-icons": "^15.0.2",
    "@react-native-community/datetimepicker": "8.6.0",
    "@sentry/react-native": "^8.5.0",
    "axios": "^1.13.6",
    "expo": "~55.0.5",
    "expo-constants": "~55.0.7",
    "expo-crypto": "~55.0.9",
    "expo-linking": "~55.0.7",
    "expo-local-authentication": "~55.0.8",
    "expo-notifications": "~55.0.12",
    "expo-router": "~55.0.5",
    "expo-secure-store": "~55.0.8",
    "expo-splash-screen": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "expo-updates": "~55.0.15",
    "expo-web-browser": "~55.0.9",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.39.1",
    "@types/react": "~19.2.2",
    "eslint": "^9.39.1",
    "eslint-config-expo": "latest",
    "prettier": "^3.6.2",
    "typescript": "~5.9.2"
  },
  "private": true
}
