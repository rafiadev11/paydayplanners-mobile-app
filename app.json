{
  "expo": {
    "owner": "powermyfitness",
    "name": "Payday Planner",
    "slug": "paydayplanners",
    "scheme": "paydayplanners",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F4EFE7"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.paydayplanners.app",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Allow PaydayPlanner to use Face ID to protect your paycheck and billing details.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.paydayplanners.app",
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      "expo-web-browser",
      "expo-notifications",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "backgroundColor": "#F4EFE7",
          "resizeMode": "contain",
          "imageWidth": 200
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "payday-planner-mobile",
          "organization": "power-my-fitness"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "befcd00c-a29b-4428-8343-60ad39794d33"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/befcd00c-a29b-4428-8343-60ad39794d33"
    }
  }
}
