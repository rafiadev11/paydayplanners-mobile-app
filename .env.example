# iOS simulator -> your Laravel API
EXPO_PUBLIC_API_URL_IOS=http://localhost

# Android emulator -> your Laravel API
EXPO_PUBLIC_API_URL_ANDROID=http://10.0.2.2

# Public legal pages host
EXPO_PUBLIC_LEGAL_URL=http://localhost

# Optional explicit legal document URLs
EXPO_PUBLIC_TERMS_URL=http://localhost/terms
EXPO_PUBLIC_PRIVACY_URL=http://localhost/privacy

# Optional local Sentry toggles
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_SENTRY_ENABLE_DEV=false
